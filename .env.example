# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Postgres ──────────────────────────────────────────────────────────────
# Local dev (Postgres running on your machine):
DATABASE_URL=postgresql://dayforge:yourpassword@localhost:5432/dayforge

# Docker Compose (app container talking to db container):
# DATABASE_URL is set automatically by compose.yml — leave blank here
# when running via Docker.

# Password used by compose.yml for the db container
DB_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────
PORT=8765

# ── AI week planning (optional) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
